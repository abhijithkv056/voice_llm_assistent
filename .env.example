# Copy to `.env` and adjust as needed. All values are optional and fall back
# to the defaults defined in voice_assistant/config.py.

# --- Ollama (LLM + embeddings) ---
OLLAMA_MODEL=mistral
# Point at a remote/containerized Ollama server if it is not local:
# OLLAMA_BASE_URL=http://localhost:11434

# --- Knowledge base ---
# KNOWLEDGE_BASE_PATH=rag/restaurant_file.txt

# --- Whisper speech-to-text ---
WHISPER_MODEL_SIZE=medium
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Conversation / logging ---
MAX_HISTORY=8
LOG_LEVEL=INFO
